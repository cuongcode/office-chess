datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  password            String
  name                String?
  emailVerified       DateTime?
  verificationToken   String?   @unique
  resetPasswordToken  String?   @unique
  resetPasswordExpiry DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  // Player profile fields
  username            String?   @unique
  avatar              String?
  bio                 String?
  
  // Game statistics
  totalGames          Int       @default(0)
  wins                Int       @default(0)
  losses              Int       @default(0)
  draws               Int       @default(0)
  rating              Int       @default(0)
  currentStreak       Int       @default(0)
  longestStreak       Int       @default(0)
  lastGameAt          DateTime?

  // Game history relations
  gamesAsWhite        Game[]    @relation("GamesAsWhite")
  gamesAsBlack        Game[]    @relation("GamesAsBlack")
}

model Game {
  id             String   @id @default(cuid())
  whitePlayerId  String
  blackPlayerId  String
  whitePlayer    User     @relation("GamesAsWhite", fields: [whitePlayerId], references: [id])
  blackPlayer    User     @relation("GamesAsBlack", fields: [blackPlayerId], references: [id])

  // Result fields
  result         String   // 'white_win' | 'black_win' | 'draw' | 'timeout_white' | 'timeout_black'
  resultMethod   String   // 'checkmate' | 'resignation' | 'draw_agreement' | 'stalemate' | 'timeout'

  // Move data
  movesPGN       String
  movesArray     Json
  finalPosition  String
  moveCount      Int

  // Time data
  timeControl    String   // e.g. "3+2" or "unlimited"
  whiteTimeLeft  Int?     // seconds remaining at game end
  blackTimeLeft  Int?     // seconds remaining at game end
  duration       Int      // seconds from start to end

  // Opening
  opening        String?

  // Timestamps
  createdAt      DateTime @default(now())
  endedAt        DateTime
}
